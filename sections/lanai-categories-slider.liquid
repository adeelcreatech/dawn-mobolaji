{% comment %}
  Section: Luxury Category Slider
  Description: A responsive slider for collection cards with video on hover,
               featuring custom navigation and edge gap detection.
  Version: 1.0.0
  Author: Shopify Section
{% endcomment %}

{{ 'https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css' | stylesheet_tag }}
{{ 'https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick-theme.css' | stylesheet_tag }}

<style>
  .slider-wrap-{{ section.id }} {
    width: 100%;
    background: {{ section.settings.background_color}};
    padding-left: 0;
    padding-right: 0;
    overflow: hidden;
    transition: padding-left 450ms ease, padding-right 450ms ease;
    border-bottom: 1px solid #DDD2C6;
    padding-bottom: 225px;
    position: relative;
  }
  .slider-wrap-{{ section.id }}.is-start {
    padding-left: clamp(18px, 4.5vw, 56px);
  }
  .slider-wrap-{{ section.id }}.is-end {
    padding-right: clamp(18px, 4.5vw, 56px);
  }
  .luxury-slider-{{ section.id }} .slider-item {
    padding-right: {{ section.settings.item_gap }}px;
    position: relative;
  }
  .card-media {
    position: relative;
    height: {{ section.settings.card_height }}px;
    overflow: hidden;
  }
  .card-image, .card-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .card-image {
    transition: opacity 240ms ease;
  }
  .card-video {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 240ms ease;
  }
  .slider-item.is-hovered .card-video {
    opacity: 1;
  }
  .slider-item.is-hovered .card-image {
    opacity: 0;
  }
  .card-title {
    margin: {{ section.settings.title_margin_top }}px 0 0;
    color: #3F3A36;
    text-align: {{ section.settings.title_alignment }};
  }
  .collection-link {
    text-decoration: none;
    display: block;
    color: inherit;
  }
  .slider-nav-{{ section.id }} {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin: {{ section.settings.nav_margin_top }}px 0 {{ section.settings.nav_margin_bottom }}px;
    position: absolute;
    top: 82%;
    left: 50%;
    transform: translate(-50%, -82%);
  }
  .slider-nav-{{ section.id }} .nav-btn {
    width: {{ section.settings.nav_button_size }}px;
    height: {{ section.settings.nav_button_size }}px;
    border: none;
    background: {{ section.settings.arrow_background_color}};
    color: {{ section.settings.nav_icon_color }};
    font-size: {{ section.settings.nav_icon_size }}px;
    line-height: 1;
    cursor: pointer;
    border-radius: {{ section.settings.nav_button_radius }}px;
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .slider-nav-{{ section.id }} .nav-btn:hover { 
    background: {{ section.settings.nav_hover_bg }};
    color: {{ section.settings.nav_hover_icon }};
    transform: scale(1.05);
  }
  .slider-nav-{{ section.id }} .nav-btn.slick-disabled { 
    opacity: 0.45; 
    cursor: not-allowed; 
    transform: none;
  }
  .slider-nav-{{ section.id }} .nav-btn svg {
    width: min({{ section.settings.nav_icon_size }}px, 13px);
    height: min({{ section.settings.nav_icon_size }}px, 13px);
    fill: currentColor;
  }

  /* Responsive Styles */
  @media (max-width: 1440px) {
    .card-media {
      height: {{ section.settings.card_height_laptop }}px;
    }
    /* Remove padding-right from last slide */
    .luxury-slider-{{ section.id }} .slider-item:last-child {
      padding-right: 0px !important;
      width: 16.66% !important;
    }
  }

  @media (max-width: 1199px) {
    .slider-wrap-{{ section.id }} {
      padding-left: 0;
      padding-right: 0;
    }
    .slider-wrap-{{ section.id }}.is-start {
      padding-left: 14px;
    }
    .slider-wrap-{{ section.id }}.is-end {
      padding-right: 14px;
    }
  }

  @media (max-width: 767px) {
    .luxury-slider-{{ section.id }} .slider-item { 
      padding-right: {{ section.settings.item_gap_mobile }}px; 
    }
    /* Mobile par bhi last slide se gap remove */
    .luxury-slider-{{ section.id }} .slider-item:last-child {
      padding-right: 0px !important;
    }
    .card-media { 
      height: {{ section.settings.card_height_mobile }}px; 
    }
  }
</style>

<section class="slider-wrap-{{ section.id }}{% if section.blocks.size > 0 %} is-start{% endif %}">
  <div style="margin: {{ section.settings.slider_margin_top }}px 0 0;" class="">
    <div class="luxury-slider-{{ section.id }}">
      {% for block in section.blocks %}
        <div class="slider-item" {{ block.shopify_attributes }}>
          {% assign collection = block.settings.collection %}
          {% assign custom_url = block.settings.custom_link %}
          {% assign link_url = custom_url %}

          {% if collection != blank and custom_url == blank %}
            {% assign link_url = collection.url %}
          {% endif %}

          {% if link_url != blank %}
            <a href="{{ link_url }}" class="collection-link">
          {% endif %}

          <div class="card-media">
            {% assign featured_image = block.settings.featured_image %}
            {% if collection != blank and featured_image == blank %}
              {% assign featured_image = collection.featured_image | default: collection.products.first.featured_image %}
            {% endif %}

            <img class="card-image" src="{{ featured_image | image_url: width: auto, height: auto, crop: 'center' }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="800" height="600">

            {% assign video_url = block.settings.video_url %}
            {% if video_url != blank %}
              <video class="card-video" muted loop playsinline preload="none">
                <source src="{{ video_url }}" type="video/mp4" />
              </video>
            {% endif %}
          </div>

          <h3 class="card-title">{{ block.settings.title | default: block.settings.collection.title | default: 'Category Name' }}</h3>

          {% if link_url != blank %}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <div class="slider-nav-{{ section.id }}"></div>

  </div>
</section>

<!-- jQuery + Slick JS -->
<!--<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js"></script>-->

<script>
  (function() {
    const sectionId = {{ section.id | json }};
    const $slider = $(`.luxury-slider-${sectionId}`);
    const $sliderWrap = $(`.slider-wrap-${sectionId}`);

    // Get custom SVG arrows from the new settings
    const customPrevSvg = {{ section.settings.custom_prev_arrow_svg | json }};
    const customNextSvg = {{ section.settings.custom_next_arrow_svg | json }};
    
    // Use custom SVGs if provided, otherwise fallback to defaults
    let prevArrowHtml = '←';
    let nextArrowHtml = '→';
    
    if (customPrevSvg && customPrevSvg.trim() !== '') {
      prevArrowHtml = customPrevSvg;
    }
    
    if (customNextSvg && customNextSvg.trim() !== '') {
      nextArrowHtml = customNextSvg;
    }
    
    // Create arrow button HTML with the SVG content
    const prevButtonHtml = `<button type="button" class="nav-btn" aria-label="Previous">${prevArrowHtml}</button>`;
    const nextButtonHtml = `<button type="button" class="nav-btn" aria-label="Next">${nextArrowHtml}</button>`;

    function resetHoverVideos() {
      $slider.find('.slider-item.is-hovered').removeClass('is-hovered');
      $slider.find('.card-video').each(function () {
        this.pause();
        this.currentTime = 0;
      });
    }

    function syncEdgeGap(slick, activeSlide) {
      const currentIndex = typeof activeSlide === 'number' ? activeSlide : (slick.currentSlide || 0);
      const visibleSlides = Number(slick.options.slidesToShow) || 1;
      const lastStartIndex = slick.slideCount - visibleSlides;
      const atStart = currentIndex <= 0;
      const atEnd = currentIndex >= (lastStartIndex - 0.01);
      $sliderWrap.toggleClass('is-start', atStart);
      $sliderWrap.toggleClass('is-end', atEnd);
      
      // Ensure last slide has no padding-right
      $slider.find('.slider-item').each(function(index) {
        if (index === slick.slideCount - 1) {
          $(this).css('padding-right', '0px');
        }
      });
    }

    $slider.on('init reInit afterChange breakpoint', function (event, slick) {
      if (!slick) return;
      syncEdgeGap(slick, slick.currentSlide);
    });

    $slider.on('beforeChange', function (event, slick, currentSlide, nextSlide) {
      if (!slick) return;
      resetHoverVideos();
      syncEdgeGap(slick, nextSlide);
    });

    $slider.on('mouseenter', '.slider-item', function () {
      const $item = $(this);
      const video = $item.find('.card-video').get(0);
      if (!video) return;

      const playPromise = video.play();
      if (playPromise && typeof playPromise.catch === 'function') {
        playPromise.catch(() => {});
      }
      $item.addClass('is-hovered');
    });

    $slider.on('mouseleave', '.slider-item', function () {
      const $item = $(this);
      const video = $item.find('.card-video').get(0);
      if (!video) return;

      video.pause();
      video.currentTime = 0;
      $item.removeClass('is-hovered');
    });

    $slider.slick({
      infinite: false,
      speed: {{ section.settings.slider_speed }},
      cssEase: 'ease-in-out',
      slidesToShow: 3.2,
      slidesToScroll: {{ section.settings.slides_to_scroll_desktop }},
      variableWidth: false,
      arrows: true,
      dots: false,
      appendArrows: `.slider-nav-${sectionId}`,
      prevArrow: prevButtonHtml,
      nextArrow: nextButtonHtml,
      responsive: [
        {
          breakpoint: 1200,
          settings: {
            slidesToShow: 2.2,
            slidesToScroll: {{ section.settings.slides_to_scroll_tablet }}
          }
        },
        {
          breakpoint: 767,
          settings: {
            slidesToShow: 1.15,
            slidesToScroll: {{ section.settings.slides_to_scroll_mobile }}
          }
        }
      ]
    });
  })();
</script>

