<style>
    .newsletter {
        background-color: {{ section.settings.bg_color }};
    }
</style>

<section class="newsletter" id="newsletter-{{ section.id }}">
  <div class="container-shell">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.description }}</p>

    {% form 'customer' %}
      {{ form.errors | default_errors }}

      {% if form.posted_successfully? %}
        <div class="alert alert-success">
          {{ section.settings.success_message }}
        </div>
      {% else %}

        <div class="input-wrap">
          <label for="newsletter-email-{{ section.id }}" class="visually-hidden">Email Address</label>
          <input id="newsletter-email-{{ section.id }}" name="contact[email]" type="email" placeholder="{{ section.settings.placeholder_text }}" value="{% if customer %}{{ customer.email }}{% endif %}" required >
          <button
            type="submit"
            name="subscribe"
            id="subscribe-{{ section.id }}"
            {% if section.settings.disable_button %}disabled style="pointer-events: none;"{% endif %}
          >
            {{ section.settings.button_text }}
          </button>
        </div>

        {% if section.settings.show_privacy_note %}
          <p class="privacy_note">{{ section.settings.privacy_note }}</p>
        {% endif %}

        <input type="hidden" name="contact[tags]" value="newsletter">

      {% endif %}
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter Section",
  "settings": [
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color",
      "default": "#F6F1E8"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Stay Inspired"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Be first to see new arrivals, outdoor styling ideas, and curated collections."
    },
    {
      "type": "text",
      "id": "placeholder_text",
      "label": "Email Placeholder",
      "default": "Email address"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Subscribe"
    },
    {
      "type": "checkbox",
      "id": "disable_button",
      "label": "Disable Button",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_privacy_note",
      "label": "Show Privacy Note",
      "default": true
    },
    {
      "type": "textarea",
      "id": "privacy_note",
      "label": "Privacy Note",
      "default": "We respect your privacy. Unsubscribe at any time."
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success Message",
      "default": "Thanks for subscribing!"
    }
  ],
  "presets": [
    {
      "name": "Newsletter Section",
      "category": "Marketing"
    }
  ]
}
{% endschema %}