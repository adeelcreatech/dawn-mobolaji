{%- assign overlay_alpha = section.settings.overlay_opacity | times: 0.01 -%}
<section class="hero">
  {%- if section.settings.video_url != blank -%}
    <video class="hero-video" autoplay muted loop playsinline preload="metadata"{% if section.settings.poster_image != blank %} poster="{{ section.settings.poster_image | image_url: width: 2200 }}"{% endif %}>
      <source src="{{ section.settings.video_url | escape }}" type="video/mp4">
    </video>
  {%- elsif section.settings.poster_image != blank -%}
    {{ section.settings.poster_image | image_url: width: 2200 | image_tag: class: 'hero-video', loading: 'lazy', alt: section.settings.heading }}
  {%- endif -%}
  <div class="hero-overlay" aria-hidden="true" style="background: rgba(0, 0, 0, {{ overlay_alpha }});"></div>

  <div class="container-shell hero-content">
    {%- if section.settings.heading != blank -%}
      <h1>{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <p>{{ section.settings.description }}</p>
    {%- endif -%}
    <div class="hero-actions">
      {%- if section.settings.primary_button_label != blank -%}
        <a class="btn-clean" href="{{ section.settings.primary_button_link | default: routes.all_products_collection_url }}">{{ section.settings.primary_button_label }}</a>
      {%- endif -%}
      {%- if section.settings.secondary_button_label != blank -%}
        <a class="btn-clean soft" href="{{ section.settings.secondary_button_link | default: routes.root_url }}">{{ section.settings.secondary_button_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mobolaji Hero",
  "settings": [
    {
      "type": "text",
      "id": "video_url",
      "label": "Background video URL (MP4)",
      "default": "https://videos.pexels.com/video-files/3209828/3209828-hd_1920_1080_25fps.mp4"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Poster image"
    },
    {
      "type": "range",
      "id": "hero_height",
      "label": "Hero height",
      "min": 320,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 780
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Quaint Elegance. Luxury Living."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Curated outdoor furniture, poolside pieces, and refined accents for elevated open-air living."
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primary button label",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label",
      "default": "Explore Inspiration"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Mobolaji Hero"
    }
  ]
}
{% endschema %}
