<div class="dagon-inner-banner" style="background: url('{{ section.settings.image_bg | img_url:''  }}');">
  <div class="container">
       <div class="row">
           <div class="col-md-12 col-xs-12 inner-banner-mid">
              <h2 class="inner-title">{{ section.settings.heading }}</h2>
           </div> 
       </div>
  </div>
</div>


<style>

.dagon-inner-banner {
    background-size: cover !important;
    background-position: center !important;
    background-repeat: no-repeat !important;
    height: 784px;
    display: flex;
    align-items: center;
    position: relative;
}
.dagon-inner-banner h2.inner-title {
    font-size: 80px;
    line-height: 90px;
    text-transform: capitalize;
    color: #fff;
    text-align: center;
}
  
</style>



{% schema %}
  {
    "name": "Mobolaji Inner Banner",
   "settings": [
            {
                "type":"image_picker",
                "id":"image_bg",
                "label":"Section Image"
            },
            {
                 "type":"text",
                 "id":"heading",
                 "label":"Page Title"
            },
            {
                "type":"color",
                "id":"txt_color",
                "label":"Text Color"
            }
    ],
    "presets": [
          {
          "name": "Mobolaji Inner Banner",
          "category": "custom"
          }
     ]
  }
{% endschema %}