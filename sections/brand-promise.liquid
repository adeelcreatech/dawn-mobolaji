<style>
    .brand-promise {
        background-color: {{ section.settings.bg_color }};
    }
    .brand-promise .brand-promise-cards .brand-promise-box {
        background-color: {{ section.settings.card_bg_color }};
    }
    .brand-promise .brand-promise-cards .brand-promise-box .brand-promise-icon-box {
        background-color: {{ section.settings.icon_bg_color }};
    }
    /* SVG stroke removed because we now use images */
</style>

<section class="brand-promise" id="brand-promise-{{ section.id }}">
  <div class="brand-promise-cards container-shell">

    {% for block in section.blocks %}
      {% if block.type == 'promise_card' %}
        <div class="brand-promise-box" {{ block.shopify_attributes }}>
          <div class="brand-promise-icon-box">
            {% if block.settings.icon_svg != blank %}
              {{
                block.settings.icon_svg
                | image_url: width: 60
                | image_tag:
                  loading: 'lazy',
                  class: 'brand-promise-icon',
                  alt: block.settings.heading
              }}
            {% else %}
              <div class="icon-placeholder">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
            {% endif %}
          </div>
          <h3>{{ block.settings.heading }}</h3>
        </div>
      {% endif %}
    {% endfor %}

  </div>
</section>

<style>
  .brand-promise-cards {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem;
    padding: 3rem 1rem;
  }
  .brand-promise-box {
    flex: 1 1 200px;
    text-align: center;
    padding: 2rem 1rem;
    border-radius: 1rem;
    transition: transform 0.2s ease;
  }
  .brand-promise-box:hover {
    transform: translateY(-5px);
  }
  .brand-promise-icon-box {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    margin-bottom: 1.5rem;
  }
  .brand-promise-icon {
    width: 40px;
    height: 40px;
    object-fit: contain;
    display: block;
  }
  .icon-placeholder {
    width: 40px;
    height: 40px;
  }
  .brand-promise-box h3 {
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 500;
    margin: 0;
    line-height: 1.4;
  }
  @media (max-width: 768px) {
    .brand-promise-cards {
      gap: 1rem;
      padding: 2rem 1rem;
    }
    .brand-promise-box {
      flex-basis: calc(50% - 1rem);
      padding: 1.5rem 0.5rem;
    }
    .brand-promise-icon-box {
      width: 60px;
      height: 60px;
    }
    .brand-promise-icon {
      width: 30px;
      height: 30px;
    }
  }
</style>

{% schema %}
{
  "name": "Brand Promise",
  "tag": "section",
  "class": "brand-promise-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color",
      "default": "#F6F1E8"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background Color",
      "default": "#FBF8F3"
    },
    {
      "type": "color",
      "id": "icon_bg_color",
      "label": "Icon Box Background Color",
      "default": "#E7D8C7"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#3F3A36"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size (px)",
      "min": 12,
      "max": 28,
      "step": 1,
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "promise_card",
      "name": "Promise Card",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Card Heading",
          "default": "Curated Premium Assortment"
        },
        {
          "type": "image_picker",
          "id": "icon_svg",
          "label": "Image Icon",
          "info": "Upload a square icon (recommended size: 80x80px)."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Promise",
      "blocks": [
        {
          "type": "promise_card",
          "settings": {
            "heading": "Curated Premium Assortment"
          }
        },
        {
          "type": "promise_card",
          "settings": {
            "heading": "Elevated Outdoor Style"
          }
        },
        {
          "type": "promise_card",
          "settings": {
            "heading": "Designed for Poolside Living"
          }
        },
        {
          "type": "promise_card",
          "settings": {
            "heading": "Quality That Lasts"
          }
        }
      ]
    }
  ],
  "max_blocks": 8
}
{% endschema %}