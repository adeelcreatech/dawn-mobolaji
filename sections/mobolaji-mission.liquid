<div class="mission-section" style="background-color: {{ section.settings.section_color }}; color: {{ section.settings.text_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    <div class="mission-grid {% if section.settings.layout == 'image_left' %}grid-reverse{% endif %}">
      <div class="mission-content">
        {% if section.settings.subheading != blank %}
          <h5 class="mission-subheading">{{ section.settings.subheading | escape }}</h5>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="mission-heading">{{ section.settings.heading | escape }}</h2>
        {% endif %}
        <div class="mission-description rte">
          {{ section.settings.descp }}
        </div>
        {% if section.settings.heading2 != blank %}
          <h2 class="mission-heading second-heading">{{ section.settings.heading2 | escape }}</h2>
        {% endif %}
        <div class="mission-description rte">
          {{ section.settings.descp2 }}
        </div>
        {% if section.settings.btn_text != blank and section.settings.btn_link != blank %}
          <a href="{{ section.settings.btn_link }}" class="mission-button">
            {{- section.settings.btn_text | escape -}}
          </a>
        {% endif %}
      </div>
      <div class="mission-image">
        {% if section.settings.image_bg != blank %}
          {{
            section.settings.image_bg
            | image_url: width: 1000
            | image_tag:
              loading: 'lazy',
              class: 'mission-img',
              alt: section.settings.image_bg.alt | default: section.settings.heading
          }}
        {% else %}
          <div class="placeholder-image">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<style>
  .mission-section {
    width: 100%;
    overflow: hidden;
  }

  .mission-section .page-width {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Grid layout (desktop) */
  .mission-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  /* Order control (image left vs right) */
  .mission-grid .mission-content {
    order: 1;
  }

  .mission-grid .mission-image {
    order: 2;
  }

  .mission-grid.grid-reverse .mission-content {
    order: 2;
  }

  .mission-grid.grid-reverse .mission-image {
    order: 1;
  }

  /* Image styling */
  .mission-img {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 1rem;
    display: block;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .mission-img:hover {
    transform: scale(1.01);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.1);
  }

  .placeholder-image {
    background: #f0f0f0;
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 300px;
  }

  .placeholder-svg {
    width: 80%;
    max-width: 250px;
    opacity: 0.5;
  }

  /* Content styling */
  .mission-subheading {
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 0.75rem 0;
    font-weight: 500;
    color: currentColor;
    opacity: 0.7;
  }

  .mission-heading {
    font-size: 2.5rem;
    font-weight: 500;
    line-height: 1.2;
    margin: 0 0 1rem 0;
    letter-spacing: -0.02em;
    color: currentColor;
  }

  .mission-heading.second-heading {
    margin-top: 1.5rem;
  }

  .mission-description {
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .mission-description p {
    margin-bottom: 1rem;
  }

  .mission-description p:last-child {
    margin-bottom: 0;
  }

  /* Button style */
  .mission-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid currentColor;
    padding: 0.75rem 2rem;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.25s ease;
    border-radius: 2rem;
    letter-spacing: 0.03em;
    color: currentColor;
    margin-top: 0.5rem;
  }

  .mission-button:hover {
    background-color: currentColor;
    color: {{ section.settings.section_color | default: '#ffffff' }};
    border-color: currentColor;
  }

  /* Responsive: mobile */
  @media screen and (max-width: 749px) {
    .mission-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .mission-grid .mission-content,
    .mission-grid .mission-image,
    .mission-grid.grid-reverse .mission-content,
    .mission-grid.grid-reverse .mission-image {
      order: unset;
    }

    .mission-heading {
      font-size: 1.8rem;
    }

    .mission-subheading {
      font-size: 0.8rem;
    }

    .mission-description {
      font-size: 0.95rem;
    }

    .mission-button {
      padding: 0.65rem 1.5rem;
      font-size: 0.85rem;
    }

    .mission-section .page-width {
      padding: 0 1.2rem;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .mission-grid {
      gap: 2rem;
    }
    .mission-heading {
      font-size: 2rem;
    }
  }
</style>

{% schema %}
{
  "name": "Mudder Mission",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_bg",
      "label": "Section Image"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Image position",
      "options": [
        { "value": "image_right", "label": "Right" },
        { "value": "image_left", "label": "Left" }
      ],
      "default": "image_right"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Sub Heading",
      "default": "Our Mission"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What We Believe"
    },
    {
      "type": "richtext",
      "id": "descp",
      "label": "Description",
      "default": "<p>We are committed to craftsmanship, cultural depth, and timeless design.</p>"
    },
    {
      "type": "text",
      "id": "heading2",
      "label": "Heading 2",
      "default": "Our Promise"
    },
    {
      "type": "richtext",
      "id": "descp2",
      "label": "Description 2",
      "default": "<p>Every piece is made with love and care, blending functionality with beauty.</p>"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Colors & Spacing"
    },
    {
      "type": "color",
      "id": "section_color",
      "label": "Background Color",
      "default": "#faf9f7"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Mudder Mission",
      "category": "custom"
    }
  ]
}
{% endschema %}